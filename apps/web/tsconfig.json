{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@mahjong/typescript-config/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },

    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "files": ["node_modules/jest-extended/types/index.d.ts"],
  "exclude": ["node_modules"]
}
